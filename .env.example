# =============================================================================
# PocUnblu — Configuration de l'environnement local
# Copier ce fichier en .env et remplir les valeurs manquantes.
# Ne jamais committer le fichier .env (il est dans .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Base de données PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_URL=jdbc:postgresql://localhost:5432/unblu_poc
DATABASE_USERNAME=unblu
DATABASE_PASSWORD=

# -----------------------------------------------------------------------------
# API Unblu
# URL de base de l'API REST Unblu v4 (valeur par défaut si absent)
# -----------------------------------------------------------------------------
UNBLU_API_BASE_URL=https://services8.unblu.com/app/rest/v4
UNBLU_API_USERNAME=
UNBLU_API_PASSWORD=

# -----------------------------------------------------------------------------
# Proxy (optionnel — laisser vide si pas de proxy)
# -----------------------------------------------------------------------------
UNBLU_PROXY_HOST=
UNBLU_PROXY_PORT=8080
UNBLU_PROXY_USERNAME=
UNBLU_PROXY_PASSWORD=

# -----------------------------------------------------------------------------
# Bot Unblu (optionnel)
# UNBLU_BOT_NAME    : nom affiché du bot dans les conversations
# -----------------------------------------------------------------------------
UNBLU_BOT_NAME=Boby

# -----------------------------------------------------------------------------
# Webhook ngrok
# UNBLU_WEBHOOK_NAME : nom unique dans Unblu — PERSONNALISER PAR DÉVELOPPEUR
#                      pour éviter les conflits sur un tenant partagé
# UNBLU_WEBHOOK_LOCAL_PORT : port local exposé par ngrok (doit correspondre au port du serveur)
# UNBLU_WEBHOOK_ENDPOINT_PATH : chemin de réception des événements Unblu
# -----------------------------------------------------------------------------
UNBLU_WEBHOOK_NAME=unblu-poc-webhook-<votre-prenom>
UNBLU_WEBHOOK_LOCAL_PORT=8081
UNBLU_WEBHOOK_ENDPOINT_PATH=/api/webhooks/unblu
